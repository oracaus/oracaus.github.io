---
import "../styles/tokens.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { SITE, SOCIAL } from "../consts";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const { title, description = SITE.description, canonical, image } = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

// Social-card image. Absolute URL is required — crawlers (LinkedIn / Facebook /
// X / Slack) don't resolve relative paths. Defaults to the branded /og-image.png;
// a page can pass its own `image` (e.g. a per-post card) to override.
const ogImageURL = new URL(image ?? "/og-image.png", Astro.site).href;

// Umami analytics: emitted in production builds only, so dev and local self-
// traffic are never counted. `data-domains` further restricts the tracker to
// the live domain, so even a local preview of the production build is ignored.
// Cookieless and GDPR-friendly, so no consent banner is required.
const isProd = import.meta.env.PROD;

// Structured data (schema.org). A sitewide Person + WebSite graph, cross-linked
// by @id, so search engines resolve oracaus.dev to a single author entity and
// follow sameAs to the off-site profiles. Machine-only; no user-facing surface.
// Post pages add a BlogPosting (PostLayout) whose author references #person.
const personId = new URL("/#person", Astro.site).href;
const websiteId = new URL("/#website", Astro.site).href;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: SITE.author,
      url: new URL("/about", Astro.site).href,
      jobTitle: SITE.role,
      knowsAbout: [
        "Real-time UI performance",
        "Front-end systems engineering",
        "React",
        "Web performance",
        "Trading and risk interfaces",
      ],
      sameAs: [SOCIAL.linkedin, SOCIAL.github, SOCIAL.devto],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: SITE.url,
      name: SITE.name,
      description: SITE.description,
      inLanguage: "en",
      publisher: { "@id": personId },
      author: { "@id": personId },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* No preload: the metric-matched fallback faces (Astro's optimizedFallbacks)
       already give zero CLS, and <Font preload> would eagerly preload every
       variant (incl. italics) and compete with the LCP. Fonts load on demand. */}
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-jetbrains-mono" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="The Oracaus wordmark over the line: interfaces that never stop updating"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="generator" content={Astro.generator} />
    {/* Soft-navigate between routes so persisted chrome (the logo) doesn't
       repaint. MPA stays the fallback if the runtime can't load. */}
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Oracaus"
      href={new URL("rss.xml", Astro.site)}
    />
    {
      isProd && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="39614114-4428-4b53-9593-42ba151aa022"
          data-domains="oracaus.dev"
        />
      )
    }
  </head>
  <body class="min-h-screen bg-bg font-sans text-fg antialiased">
    <SiteHeader />
    <main class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
