---
import "../styles/tokens.css";
import { Font } from "astro:assets";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { SITE } from "../consts";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const { title, description = SITE.description, canonical, image } = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

// Social-card image. Absolute URL is required — crawlers (LinkedIn / Facebook /
// X / Slack) don't resolve relative paths. Defaults to the branded /og-image.png;
// a page can pass its own `image` (e.g. a per-post card) to override.
const ogImageURL = new URL(image ?? "/og-image.png", Astro.site).href;

// Umami analytics: emitted in production builds only, so dev and local self-
// traffic are never counted. `data-domains` further restricts the tracker to
// the live domain, so even a local preview of the production build is ignored.
// Cookieless and GDPR-friendly, so no consent banner is required.
const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* No preload: the metric-matched fallback faces (Astro's optimizedFallbacks)
       already give zero CLS, and <Font preload> would eagerly preload every
       variant (incl. italics) and compete with the LCP. Fonts load on demand. */}
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-jetbrains-mono" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="The Oracaus wordmark over the line: interfaces that never stop updating"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Oracaus"
      href={new URL("rss.xml", Astro.site)}
    />
    {
      isProd && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="39614114-4428-4b53-9593-42ba151aa022"
          data-domains="oracaus.dev"
        />
      )
    }
  </head>
  <body class="min-h-screen bg-bg font-sans text-fg antialiased">
    <SiteHeader />
    <main class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
