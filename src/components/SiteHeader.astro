---
const nav = [
  { href: "/blog/", label: "Writing" },
  { href: "/work/", label: "Work" },
  { href: "/about/", label: "About" },
];
const path = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a
      href="/"
      transition:persist
      class="flex items-center gap-1.5 font-mono text-sm font-semibold tracking-tight"
    >
      <svg viewBox="0 0 18 18" class="h-3.5 w-3.5 shrink-0" aria-hidden="true">
        <circle
          cx="9"
          cy="9"
          r="7"
          fill="none"
          stroke-width="3.2"
          class="stroke-accent-info"></circle>
      </svg>
      Oracaus
    </a>
    <ul class="flex gap-5 text-sm text-fg-muted">
      {
        nav.map((i) => (
          <li>
            <a
              href={i.href}
              class:list={[
                "transition-colors hover:text-fg",
                { "text-fg": path.startsWith(i.href) },
              ]}
            >
              {i.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
